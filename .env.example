# TwistedNews Configuration Template
# Copy this file to .env and configure with your settings

# TwistedPair API Settings
TWISTEDPAIR_BASE_URL=http://localhost:8001
TWISTEDPAIR_TIMEOUT=300

# TwistedPair Distortion Parameters
# Mode options: invert_er, so_what_er, echo_er, what_if_er, cucumb_er, archiv_er
TWISTEDPAIR_MODE=so_what_er

# Tone options: neutral, technical, primal, poetic, satirical
TWISTEDPAIR_TONE=technical

# Gain: 1-10 (intensity level)
TWISTEDPAIR_GAIN=6

# Ollama Settings
OLLAMA_MODEL=qwen3:latest
OLLAMA_NUM_CTX=128000

# Prompt Template Style
# Options: comprehensive (detailed analysis), simple (basic summary), raw (no prompt wrapper)
PROMPT_STYLE=comprehensive

# Email Configuration (same as NewsAgent)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=recipient@example.com

# Optional: Logging and Debug
LOG_LEVEL=INFO
VERBOSE=False
DEBUG=False
